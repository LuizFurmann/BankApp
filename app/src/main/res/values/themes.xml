<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.SecutiryStudy" parent="Theme.Material3.DayNight.NoActionBar" />

    <style name="Theme.SecutiryStudy" parent="Base.Theme.SecutiryStudy" />

    <style name="CustomBottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemHorizontalTranslationEnabled">false</item>

        <item name="android:minHeight">56dp</item>
        <item name="itemIconSize">28dp</item>
        <item name="itemPaddingTop">10dp</item>
        <item name="itemPaddingBottom">0dp</item>

        <!-- Aqui vamos referenciar o seletor -->
        <item name="itemIconTint">@color/bottom_nav_icon_color</item>
        <item name="itemTextColor">@color/bottom_nav_icon_color</item>

        <item name="android:fitsSystemWindows">false</item>
        <item name="android:clipToPadding">false</item>
        <item name="android:clipChildren">false</item>
    </style>

    <style name="BottomNavTextActive" parent="@style/TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">14sp</item>
    </style>

    <style name="BottomNavTextInactive" parent="@style/TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">13sp</item>
    </style>
</resources>
